<Window x:Class="EdiStudio.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:EdiStudio"
        mc:Ignorable="d"
        Title="{Binding Titulo}" Height="600" Width="800">
    <DockPanel>
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="_Arquivo">
                <MenuItem 
                    Header="_Abrir Layout"
                    Command="{Binding AbrirLayoutCommand}"
                />
                <MenuItem 
                    Header="_Novo Layout"
                    Command="{Binding NovoLayoutCommand}"
                />
            </MenuItem>
        </Menu>

        <StatusBar DockPanel.Dock="Bottom">
            <StatusBarItem>
                <TextBlock Text="{Binding StatusLayout}"/>
            </StatusBarItem>
        </StatusBar>

        <Grid Margin="10">
            <TextBlock
                Text="Nenhum arquivo EDI carregado."
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                FontSize="18"
                Opacity="0.5"
            />
        </Grid>
    </DockPanel>
</Window>
