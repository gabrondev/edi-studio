<Window x:Class="EdiStudio.Views.LayoutWizardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:EdiStudio.Views"
        xmlns:wizardVm="clr-namespace:EdiStudio.ViewModels.Wizard"
        xmlns:wizardViews="clr-namespace:EdiStudio.Views.Wizard"
        mc:Ignorable="d"
        Title="EDI Studio - Assistente de Criação de Layout" Height="600" Width="800">
    
    <Window.Resources>
        <DataTemplate DataType="{x:Type wizardVm:DadosGeraisLayoutStepViewModel}">
            <wizardViews:DadosGeraisLayoutStepView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type wizardVm:TiposRegistroStepViewModel}">
            <wizardViews:TiposRegistroStepView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type wizardVm:CamposRegistroStepViewModel}">
            <wizardViews:CamposRegistroStepView />
        </DataTemplate>
    </Window.Resources>

    <DockPanel Margin="10">
        <StackPanel DockPanel.Dock="Top" Margin="0,0,0,10">
            <TextBlock Text="Criação de Layout"
                       FontSize="24"
                       FontWeight="Bold"/>
            <TextBlock Text="{Binding IndicadorEtapa}"
                       FontSize="13"
                       Margin="0,8,0,0"/>
            <TextBlock Text="{Binding TituloEtapa}"
                       FontSize="16"
                       FontWeight="SemiBold"
                       Margin="0,8,0,0"/>
        </StackPanel>

        <StackPanel DockPanel.Dock="Bottom"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,20,0,0">
            <Button Content="Voltar"
                    Command="{Binding VoltarCommand}"
                    Width="100"
                    Margin="0,0,10,0"/>
            <Button Content="{Binding TextoBotaoProximo}"
                    Command="{Binding ProximoCommand}"
                    Width="100"/>
        </StackPanel>

        <ContentControl Content="{Binding EtapaAtualViewModel}"/>
    </DockPanel>
</Window>
