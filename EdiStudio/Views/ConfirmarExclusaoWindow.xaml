<Window x:Class="EdiStudio.Views.ConfirmarExclusaoWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:EdiStudio.Views"
        mc:Ignorable="d"
        Title="ConfirmarExclusaoWindow" Width="460">
    <StackPanel Margin="20">
        <TextBlock Text="Confirmar exclusão"
                   FontSize="16"
                   FontWeight="SemiBold"
                   Margin="0,0,0,12" />

        <TextBlock x:Name="MensagemTextBlock"
                   TextWrapping="Wrap"
                   Margin="0,0,0,16" />

        <CheckBox x:Name="ExcluirSomenteSelecionadoCheckBox"
                  Margin="0,0,0,20">
            <TextBlock Text="Excluir somente a linha selecionada (pode deixar registros órfãos)"
                       TextWrapping="Wrap" />
        </CheckBox>

        <StackPanel Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <Button Content="Cancelar"
                    Width="85"
                    Margin="0,0,8,0"
                    IsCancel="True" />

            <Button Content="Excluir"
                    Width="85"
                    IsDefault="True"
                    Click="Excluir_Click" />
        </StackPanel>
    </StackPanel>
</Window>
