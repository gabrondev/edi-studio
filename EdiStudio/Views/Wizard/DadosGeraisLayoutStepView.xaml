<UserControl x:Class="EdiStudio.Views.Wizard.DadosGeraisLayoutStepView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:EdiStudio.Views.Wizard"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <StackPanel>
        <TextBlock Text="Nome do Layout"
                   FontWeight="SemiBold"
                   Margin="0,0,0,5"/>
        <TextBox Text="{Binding NomeLayout, UpdateSourceTrigger=PropertyChanged}"
                 Height="28"
                 Width="300"
                 HorizontalAlignment="Left"
                 Margin="0,0,0,15"/>

        <TextBlock Text="Tipo de EDI"
                   FontWeight="SemiBold"
                   Margin="0,0,0,5"/>
        <ComboBox ItemsSource="{Binding TiposEdiDisponiveis}"
                  SelectedItem="{Binding TipoEdiSelecionado}"
                  Width="200"
                  Height="28"
                  HorizontalAlignment="Left"/>
    </StackPanel>
</UserControl>
